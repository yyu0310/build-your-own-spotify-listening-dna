# Copy this file to ~/.config/spotify-dna/.env and fill in your values.
# Or set SECRETS_DIR=/your/path and place .env there.
#
#   mkdir -p ~/.config/spotify-dna
#   cp .env.example ~/.config/spotify-dna/.env
#   nano ~/.config/spotify-dna/.env

# -------------------------------------------------------------------
# SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET
# -------------------------------------------------------------------
# How to get:
#   1. Go to https://developer.spotify.com/dashboard and log in
#   2. Click "Create app"
#   3. Set Redirect URI to:  http://127.0.0.1:8888/callback
#   4. Under Settings → show Client ID and Client Secret
# -------------------------------------------------------------------
SPOTIFY_CLIENT_ID=YOUR_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# -------------------------------------------------------------------
# SPOTIFY_SHEET_ID  (optional — only needed for Google Sheets sync)
# -------------------------------------------------------------------
# How to get:
#   The spreadsheet ID is in the URL:
#   https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# -------------------------------------------------------------------
SPOTIFY_SHEET_ID=YOUR_SPREADSHEET_ID_HERE

# -------------------------------------------------------------------
# LASTFM_API_KEY  (optional — for Last.fm scrobble history import)
# -------------------------------------------------------------------
# How to get:
#   1. Go to https://www.last.fm/api/account/create
#   2. Fill in the form and copy the API key
# -------------------------------------------------------------------
LASTFM_API_KEY=YOUR_LASTFM_API_KEY_HERE

# -------------------------------------------------------------------
# YOUTUBE_API_KEY  (optional — for tools/youtube_url_lookup.py)
# -------------------------------------------------------------------
# How to get:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → Enable "YouTube Data API v3"
#   3. Credentials → Create API Key
# Notes:
#   - Free quota: 100 search units/day (each lookup = 1 unit)
#   - Only needed if yt-dlp search is failing for many tracks
# -------------------------------------------------------------------
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# -------------------------------------------------------------------
# GSHEET_SA_KEY_PATH  (optional — Google Sheets service account)
# -------------------------------------------------------------------
# How to get:
#   1. Google Cloud Console → IAM → Service Accounts → Create
#   2. Grant "Editor" role on your spreadsheet
#   3. Create JSON key and download it
#   4. Set the path below (default: ~/.config/spotify-dna/service_account.json)
# -------------------------------------------------------------------
# GSHEET_SA_KEY_PATH=/path/to/service_account.json
